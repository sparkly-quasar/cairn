{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cairn",
  "version": "0.5.3",
  "identifier": "com.cairn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Cairn",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3OTFFNEMwNTkyMkY1MDcKUldRSDlTSlp3T1NSSjJOTTJLZ1lRU2dsd3pxZ3NMd2tORkgwREZITzBZMWhZbUp3Q29Db25LWEsK",
      "endpoints": [
        "https://github.com/sparkly-quasar/cairn/releases/latest/download/latest.json"
      ]
    }
  }
}
